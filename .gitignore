# Copyright-sensitive local datasets and derived caches
raw_chart_data/
cache/
sample_runs/
manifests/
reports/*
!reports/repository_health/
reports/repository_health/latest.json
reports/repository_health/latest.md
reports/repository_health/history/

# Local agent/workspace metadata
.gitignore
agents.md

# Local Python environments and bundled runtimes
.venv/
tools/*
!tools/analyze_pattern_labels.py
!tools/check_git_health.py
!tools/check_data_health.py
!tools/check_experiment_health.py
